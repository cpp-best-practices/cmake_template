# Regression test for issue #143: CPM dependencies should use SYSTEM includes
# natively via CPM's SYSTEM option, not through SystemLink.cmake

set(fmt_dir_system "@_fmt_dir_system@")

if(NOT fmt_dir_system)
  message(FATAL_ERROR
    "The fmt source directory does not have the SYSTEM property set.\n"
    "CPM dependencies should be declared with SYSTEM YES so their headers\n"
    "are treated as system includes without needing SystemLink.cmake.")
endif()

message(STATUS "PASS: fmt source directory has SYSTEM property set")
